# ─── Сервер ──────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGIN=*

# ─── База данных ─────────────────────────────────────────
# Если DATABASE_URL задан — используется PostgreSQL.
# Если не задан — используется SQLite (файл в DATA_DIR).
# DATABASE_URL=postgres://parking:parking_secret@localhost:5432/parking
# DB_TYPE=postgres  (авто: postgres если есть DATABASE_URL, иначе sqlite)

# ─── Пути (для SQLite / сидов) ───────────────────────────
# DATA_DIR=./data
# STATIC_DIR=./public

# ─── Бизнес-логика ───────────────────────────────────────
MIN_BOOKING_HOURS=1

# ─── Логирование ─────────────────────────────────────────
LOG_LEVEL=info
